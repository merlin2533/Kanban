# Kanban Board - Environment Variables
# Copy to .env and adjust values

# Server
PORT=3000
APP_URL=http://localhost:3000
NODE_ENV=production

# Admin credentials (only used on first run)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# PostgreSQL Database
POSTGRES_DB=kanban
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/kanban

# sgit_ticket service
SGIT_TICKET_IMAGE=merlin2539/sgit_ticket:latest
SGIT_TICKET_PORT=3200
BASE_URL=http://localhost:3200

# Email (Resend) - can also be set/overridden via Admin UI → Einstellungen
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=support@yourdomain.com

# Reminders - can also be set via Admin UI → Einstellungen
REMINDER_INTERVAL_HOURS=24
REMINDER_ESCALATION_DAYS=3

# External API key - auto-generated on first start, manageable via Admin UI → Einstellungen
API_KEY=

# Webhooks
INBOUND_WEBHOOK_SECRET=

# Docker image (for docker-compose pull)
IMAGE=merlin2539/kanban:latest
