# Kanban Board - Environment Variables
# Copy to .env and adjust values

# Server
PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=production

# Database (inside container: /data/kanban.db)
DB_PATH=/data/kanban.db

# Default admin credentials (only used on first run)
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# Docker image (for docker-compose pull)
IMAGE=merlin2533/kanban:latest
